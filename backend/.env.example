MONGODB_URI=mongodb://localhost:27017/railmind
# What: Connection string for MongoDB (used for logging incidents, reports, and department tasks)
# Get it: Use local MongoDB Community Edition or sign up at https://www.mongodb.com/cloud/atlas/register
# Cost: Free / Free Tier available

GEMINI_API_KEY=your_key_here
# What: Gemini Developer API key (used for multi-agent reasoning and decision making)
# Get free forever at: aistudio.google.com
# Cost: Free tier available

ANTHROPIC_API_KEY=your_key_here
# What: Claude Developer API key (used as fallback for reasoning when Gemini fails)
# Optional fallback: console.anthropic.com
# Cost: Paid (free trial credits sometimes available)

TWILIO_ACCOUNT_SID=your_sid_here
# What: Twilio Account SID (used to send operations and coordinator warnings via Twilio SMS)
# Get it: Sign up at https://www.twilio.com/try-twilio
# Cost: Free trial available (paid per SMS message thereafter)

TWILIO_AUTH_TOKEN=your_token_here
# What: Twilio Auth Token (used to authenticate the Twilio SMS alert API client)
# Get it: Sign up at https://www.twilio.com/try-twilio
# Cost: Free trial available

TWILIO_PHONE_NUMBER=your_twilio_number_here
# What: Active Twilio phone number with SMS capabilities
# Get it: Claim a phone number in the Twilio Console (https://console.twilio.com)
# Cost: Free trial covers first number

TWILIO_TEST_PHONE=your_personal_number_here
# What: Recipient mobile number to receive live Twilio test SMS alerts
# Get it: Your personal active mobile number
# Cost: Free (receives message)

DEMO_MODE=true
# What: Flag to disable paid API connections (Railways API/Twilio SMS alerts) and use mock fallbacks instead
# Get it: N/A - Set to 'true' or 'false'
# Cost: Free

RAPIDAPI_KEY=your_key_here
# What: RapidAPI IRCTC API Key
# Get it: https://rapidapi.com/IRCTCAPI/api/irctc1/
# Cost: Free tier / Paid packages available

RAPIDAPI_HOST=irctc1.p.rapidapi.com
# What: RapidAPI IRCTC Host

